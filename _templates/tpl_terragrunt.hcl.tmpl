# AUTO-GENERATED by Terramate — do not edit manually
# Source template: _templates/tpl_terragrunt.hcl.tmpl

terraform {
  source = "${terraform_source}"
}

include "root" {
  path   = find_in_parent_folders("terragrunt.hcl")
  expose = true
}

# ---------------------------------------------------------------------------
# Hooks
# ---------------------------------------------------------------------------

terraform_binary = "${terraform_binary}"

terraform {
  before_hook "init_check" {
    commands = ["init"]
    execute  = ["echo", "==> Initialising stack: ${stack_path}"]
  }

  after_hook "init_success" {
    commands     = ["init"]
    execute      = ["echo", "==> Init complete"]
    run_on_error = false
  }

  before_hook "plan_check" {
    commands = ["plan"]
    execute  = ["echo", "==> Planning stack: ${stack_path} (env: ${env})"]
  }

  after_hook "plan_output" {
    commands     = ["plan"]
    execute      = ["sh", "-c", "echo '==> Plan finished. Review before applying.'"]
    run_on_error = true
  }

  before_hook "apply_guard" {
    commands = ["apply"]
    execute  = ["echo", "==> Applying stack: ${stack_path}"]
  }

  after_hook "apply_notify" {
    commands     = ["apply"]
    execute      = ["echo", "==> Apply complete for ${stack_path}"]
    run_on_error = false
  }

  before_hook "destroy_guard" {
    commands = ["destroy"]
    execute  = ["echo", "WARNING: Destroying ${stack_path} in ${env}"]
  }
}

# ---------------------------------------------------------------------------
# Inputs — merged from globals declared in each stack
# ---------------------------------------------------------------------------

inputs = ${tm_jsonencode(inputs)}
