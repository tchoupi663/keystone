# Set default behavior to handle all files as text and normalize to LF.
* text=auto eol=lf

# Explicitly declare files that should always use LF.
*.tf text eol=lf
*.tfvars text eol=lf
*.tm.hcl text eol=lf
*.alloy.tpl text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Denote all files that are truly binary and should not be modified.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.webp binary
